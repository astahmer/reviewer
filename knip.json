{
    "$schema": "https://unpkg.com/knip@latest/schema.json",
    "entry": [
        "bin/**/*.mjs",
        "src/query-client.ts",
        "src/router.tsx",
        "src/routes/**/*.{ts,tsx}",
        "src/server/**/*.ts",
        "features/**/*.{ts,tsx}",
        "tests/**/*.{ts,tsx}"
    ],
    "project": [
        "src/**/*.{ts,tsx}",
        "features/**/*.{ts,tsx}",
        "tests/**/*.{ts,tsx}",
        "bin/**/*.mjs",
        "*.ts"
    ],
    "ignoreIssues": {
        "src/adapters/storage/storage.interface.ts": [
            "exports"
        ],
        "src/adapters/vcs/vcs.interface.ts": [
            "exports"
        ],
        "src/components/hooks.ts": [
            "exports"
        ],
        "src/effects/runtime.ts": [
            "exports"
        ],
        "src/effects/services/vcs-service.ts": [
            "exports"
        ],
        "src/lib/errors.ts": [
            "exports"
        ]
    },
    "ignoreDependencies": [
        "chrome-devtools-mcp",
        "nitro"
    ]
}
