{
  "name": "reviewer",
  "version": "0.0.1",
  "description": "Local-first high-performance git diff reviewer",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc --noEmit",
    "preview": "vite preview",
    "start": "node .output/server/index.mjs",
    "typecheck": "tsc --noEmit --pretty",
    "go": "tsgo --noEmit --pretty",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "check": "pnpm run typecheck && pnpm run lint"
  },
  "dependencies": {
    "@ark-ui/react": "5.34.1",
    "@effect/platform": "0.94.5",
    "@pierre/diffs": "1.1.3",
    "@tanstack/react-db": "0.1.74",
    "@tanstack/react-pacer": "0.20.0",
    "@tanstack/react-query": "5.90.21",
    "@tanstack/react-router": "1.163.3",
    "@tanstack/react-router-ssr-query": "1.163.3",
    "@tanstack/react-start": "1.166.1",
    "@tanstack/react-virtual": "3.13.19",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "effect": "3.19.19",
    "jsdiff": "1.1.1",
    "lucide-react": "0.576.0",
    "match-sorter": "8.2.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "3.5.0",
    "zipson": "0.2.12"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.2.1",
    "@types/node": "25.3.3",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260303.1",
    "@vitejs/plugin-react": "5.1.4",
    "chrome-devtools-mcp": "0.18.1",
    "nitro": "3.0.1-alpha.2",
    "oxfmt": "0.36.0",
    "oxlint": "1.51.0",
    "oxlint-tsgolint": "0.16.0",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "unplugin-jsx-source": "0.1.5",
    "vite": "7.3.1",
    "vite-tsconfig-paths": "6.1.1"
  },
  "packageManager": "pnpm@10.16.0"
}
