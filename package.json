{
  "name": "reviewer",
  "version": "0.0.1",
  "description": "Local-first high-performance git diff reviewer",
  "type": "module",
  "bin": {
    "reviewer": "./bin/reviewer.mjs"
  },
  "scripts": {
    "dev": "vite",
    "dev:e2e": "vite --host 127.0.0.1 --port 4173",
    "build": "vite build && tsc --noEmit",
    "preview": "vite preview",
    "start": "node dist/server/server.js",
    "cli": "node ./bin/reviewer.mjs",
    "bddgen": "bddgen",
    "test": "pnpm test:unit",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "pnpm bddgen && playwright test",
    "typecheck": "tsc --noEmit --pretty",
    "go": "tsgo --noEmit --pretty",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "knip": "knip",
    "lint": "pnpm run lint:ox && pnpm run lint:knip",
    "lint:fix": "pnpm run lint:ox --fix",
    "lint:knip": "knip",
    "lint:ox": "oxlint",
    "check": "pnpm run typecheck && pnpm run lint"
  },
  "dependencies": {
    "@ark-ui/react": "5.34.1",
    "@pierre/diffs": "1.1.3",
    "@tanstack/react-pacer": "0.20.0",
    "@tanstack/react-query": "5.90.21",
    "@tanstack/react-router": "1.163.3",
    "@tanstack/react-router-ssr-query": "1.163.3",
    "@tanstack/react-start": "1.166.1",
    "effect": "3.19.19",
    "lucide-react": "0.576.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zipson": "0.2.12"
  },
  "devDependencies": {
    "@effect/language-service": "^0.85.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "4.2.1",
    "@types/node": "25.3.3",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260303.1",
    "@vitejs/plugin-react": "5.1.4",
    "chrome-devtools-mcp": "0.18.1",
    "knip": "^6.4.1",
    "nitro": "3.0.1-alpha.2",
    "oxfmt": "0.36.0",
    "oxlint": "1.51.0",
    "oxlint-tsgolint": "0.16.0",
    "playwright-bdd": "^8.5.0",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "unplugin-jsx-source": "0.1.5",
    "vite": "7.3.1",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "^4.1.4"
  },
  "packageManager": "pnpm@10.16.0"
}
