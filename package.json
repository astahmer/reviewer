{
  "name": "reviewer",
  "version": "0.0.1",
  "description": "Local-first high-performance git diff reviewer",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc --noEmit",
    "preview": "vite preview",
    "start": "node .output/server/index.mjs",
    "typecheck": "tsc --noEmit --pretty",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "check": "pnpm run typecheck && pnpm run lint"
  },
  "dependencies": {
    "@effect/platform": "^0.65.0",
    "@tanstack/react-db": "^0.1.73",
    "@tanstack/react-query": "^5.71.10",
    "@tanstack/react-router": "^1.67.0",
    "@tanstack/react-start": "^1.67.0",
    "@tanstack/react-virtual": "^3.12.0",
    "effect": "^3.13.0",
    "jsdiff": "^1.1.0",
    "match-sorter": "^6.3.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.12.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.4.4",
    "chrome-devtools-mcp": "0.18.1",
    "nitro": "^3.0.0-rc.1",
    "oxc": "^1.0.0",
    "oxlint": "^1.50.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.3",
    "vite": "^6.0.11",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "packageManager": "pnpm@10.16.0"
}
